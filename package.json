{
  "name": "langgraph-stage0-gate",
  "version": "1.0.0",
  "description": "Stage0 Runtime Gate for LangGraph agents - Protects your AI agents from unauthorized tool execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "demo:allow": "tsx src/index.ts --scenario allow",
    "demo:deny": "tsx src/index.ts --scenario deny",
    "demo:all": "tsx src/index.ts --scenario all",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "langgraph",
    "langchain",
    "ai-agent",
    "runtime-guard",
    "policy",
    "stage0",
    "signalpulse"
  ],
  "author": "Starlight143",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Starlight143/langgraph-stage0-gate.git"
  },
  "bugs": {
    "url": "https://github.com/Starlight143/langgraph-stage0-gate/issues"
  },
  "homepage": "https://github.com/Starlight143/langgraph-stage0-gate#readme",
  "dependencies": {
    "dotenv": "^16.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}